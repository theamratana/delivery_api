# =============================================================================
# Roluun Delivery API — Production Environment Configuration
# =============================================================================
# Usage:
#   cp .env.example .env
#   nano .env          ← fill in your values
#   ./deploy.sh start
#
# After editing .env, run:  ./deploy.sh restart
# After new code:           ./deploy.sh rebuild
# =============================================================================

# ─── Database ────────────────────────────────────────────────────────────────
# DB_URL is automatically set to internal Docker network (roluun-db:5432)
# Do NOT set DB_URL here — it is managed by docker-compose.prod.yml
DB_NAME=deliverydb
DB_USERNAME=postgres
DB_PASSWORD=change_this_strong_password

# ─── Server ──────────────────────────────────────────────────────────────────
SERVER_PORT=8081

# ─── JWT Security ────────────────────────────────────────────────────────────
# IMPORTANT: Use a long random string in production (min 32 chars)
# Generate one with: openssl rand -hex 32
JWT_SECRET=replace_this_with_a_very_long_random_secret_string
JWT_ISSUER=delivery-api
JWT_ACCESS_EXP_MINUTES=14400
JWT_REFRESH_EXP_MINUTES=10080
JWT_DEV_ENABLED=false

# ─── Telegram Bot ────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_BOT_USERNAME=RoluunBot
TELEGRAM_POLLING_ENABLED=true

# ─── Upload Limits ───────────────────────────────────────────────────────────
UPLOAD_MAX_FILE_SIZE=10MB
UPLOAD_MAX_REQUEST_SIZE=50MB

# ─── JPA / Hibernate ─────────────────────────────────────────────────────────
# Use 'validate' in production to prevent accidental schema changes
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false

# ─── Database Pool (optional tuning) ─────────────────────────────────────────
# DB_POOL_MAX=20
# DB_POOL_MIN_IDLE=5
# DB_POOL_CONNECTION_TIMEOUT=20000
# DB_POOL_IDLE_TIMEOUT=300000
# DB_POOL_MAX_LIFETIME=1200000
